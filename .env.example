# PRODUCTION ENVIRONMENT VARIABLES EXAMPLE
# Rename this file to .env and fill in the values for your live server.

# Server Configuration
PORT=5000
NODE_ENV=production
BASE_URL=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# Database Configuration (MySQL)
# Use either a connection URL or individual parameters
# DATABASE_URL=mysql://user:password@host:port/database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=fashion_redemption
MYSQL_SSL=true

# Espees Payment Configuration
# Get these from your Espees Developer Dashboard
ESPEES_API_KEY=your_espees_api_key
ESPEES_MERCHANT_WALLET=your_espees_wallet_address

# Email Configuration (SMTP)
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM="Fashion Redemption <noreply@yourdomain.com>"

# JWT Configuration
JWT_SECRET=your_super_secret_random_string

# Frontend specific variables (for Vite)
# These usually go in a separate .env file in the root if using Vite
VITE_API_URL=https://your-backend-domain.com/api

# API Security configuration
# REDEMPTION_API_KEY must match VITE_REDEMPTION_API_KEY
REDEMPTION_API_KEY=your_secure_backend_api_key
VITE_REDEMPTION_API_KEY=your_secure_backend_api_key

# CLOUDINARY CONFIGURATION (for cloud image hosting & optimization)
# Sign up free at https://cloudinary.com and copy values from your dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Folder where images are stored (optional, defaults to 'redemption/products')
CLOUDINARY_FOLDER=redemption/products


